# SAS — Atendimento Psicológico — exemplo de configuração.
# Copie para .env (Docker) ou .env.local (dev) e preencha os valores reais.

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Banco de dados (Supabase / Postgres) ──────────────────────────────────────
# Use o pooler de TRANSAÇÕES do Supabase (porta 6543) — o driver postgres-js roda
# com prepare:false por causa dele. Pegue a string em:
#   Supabase → Project Settings → Database → Connection string → "Transaction pooler".
DATABASE_URL=postgresql://postgres.<project>:<senha>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Autenticação (OAuth Manus) ────────────────────────────────────────────────
JWT_SECRET=troque-por-uma-chave-secreta-forte
VITE_APP_ID=seu-app-id-manus
OAUTH_SERVER_URL=https://api.manus.im

# Login de DESENVOLVIMENTO (só local, NUNCA em produção): quando true e
# NODE_ENV=development, entra automaticamente como um terapeuta de teste,
# permitindo usar os fluxos protegidos sem configurar o OAuth.
DEV_AUTH=false

# ── Supabase Auth (login real) ────────────────────────────────────────────────
# Frontend (embutidas no bundle): URL do projeto e a publishable key (pública).
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Backend: valida o JWT via JWKS do projeto (não precisa de segredo). Requer as
# signing keys ASSIMÉTRICAS habilitadas no Supabase (Settings → JWT Keys).
SUPABASE_URL=https://<project>.supabase.co
# Opcional (derivado de SUPABASE_URL se omitido):
# SUPABASE_JWKS_URL=https://<project>.supabase.co/auth/v1/.well-known/jwks.json

# ── Videochamada (MiroTalk SFU) ───────────────────────────────────────────────
# Padrão: instância pública do MiroTalk (não precisa hospedar nada).
# Para self-host (gravação própria), suba via Docker e use https://localhost:3010.
VITE_MIROTALK_URL=https://sfu.mirotalk.com

# ── Lembretes por e-mail (SMTP) ───────────────────────────────────────────────
# Ative o agendador (roda o ciclo a cada 15 min). Sem SMTP, fica em dry-run (loga).
NOTIFICATIONS_ENABLED=false
# Recebe o aviso quando alguém solicita acesso como psicóloga.
# Se vazio, usa o e-mail do usuário com papel `admin`.
ADMIN_EMAIL=
#
# Gmail: use uma SENHA DE APP (16 caracteres), não a senha da conta.
# Requer verificação em 2 etapas ligada → myaccount.google.com/apppasswords
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=seu@gmail.com
#   SMTP_PASS=<senha de app>
#   SMTP_FROM=seu@gmail.com     (o Gmail exige que o From seja a própria conta)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
